<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!--
      AuthX SDK logging demo — SDK-only output.

      Pattern shows, for every line:
        - timestamp + level
        - [trace=...] prefix (added by LogCtx when a span is active)
        - from MDC: authx.action / authx.resourceType:authx.resourceId / authx.subject / authx.consistency
        - logger name (short)
        - message body
      MDC placeholders use "-" as default so lines without SDK context still align.

      Framework noise (Spring Boot, Tomcat, gRPC, Netty) is routed to /dev/null
      via root=OFF. Only loggers under com.authx.sdk reach the console.
    -->
    <property name="PATTERN"
              value="%d{HH:mm:ss.SSS} %-5level [%X{authx.action:--} %X{authx.resourceType:--}:%X{authx.resourceId:--} subj=%X{authx.subject:--} consistency=%X{authx.consistency:--}] %logger{30} - %msg%n"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${PATTERN}</pattern>
        </encoder>
    </appender>

    <!--
      Only SDK lines reach the console.
      additivity="false" prevents them bubbling up to root (which is OFF anyway).
    -->
    <logger name="com.authx.sdk" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- Everything else silenced. -->
    <root level="OFF"/>

</configuration>
